import sqlite3


def __connect_to_db():
    conn = sqlite3.connect("data/insight.db")
    cursor = conn.cursor()
    return conn, cursor


def __close_db(conn):
    conn.commit()
    conn.close()


# pr_workitem_details Table Operations
def insert_into_pr_workitem_details_table(pr_id, repo_id, workitem_id):
    conn, cursor = __connect_to_db()
    try:
        cursor.execute(
            """
                INSERT INTO pr_workitem_details (pr_id, repo_id, workitem_id)
                VALUES (?, ?, ?);
            """,
            (pr_id, repo_id, workitem_id),
        )
    finally:
        __close_db(conn)


def update_pr_workitem_details_table(pr_id, workitem_id):
    conn, cursor = __connect_to_db()
    try:
        cursor.execute(
            """
                UPDATE pr_workitem_details SET workitem_id=?
                WHERE pr_id=?
            """,
            (workitem_id, pr_id),
        )
    finally:
        __close_db(conn)


def get_all_pr_ids():
    conn, cursor = __connect_to_db()
    try:
        cursor.execute(
            """
                SELECT DISTINCT pr_id FROM pr_workitem_details;
            """
        )
        rows = (
            cursor.fetchall()
        )  # This returns a list of tuples, e.g., [(1,), (2,), (3,)]
        ids = [row[0] for row in rows]  # Extract the first element from each tuple
        return ids
    finally:
        __close_db(conn)


