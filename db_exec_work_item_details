import sqlite3


def __connect_to_db():
    conn = sqlite3.connect("data/insight.db")
    cursor = conn.cursor()
    return conn, cursor


def __close_db(conn):
    conn.commit()
    conn.close()


def truncate_workitem_details_table():
    conn, cursor = __connect_to_db()
    try:
        cursor.execute(
            """
            DELETE FROM workitem_details;
        """
        )
    finally:
        __close_db(conn)


# workitem_details Table Operations
def insert_into_workitem_details_table(
    id,
    title,
    type,
    severity,
    priority,
    feature,
    target_release,
    status,
    exists_in_sit,
    exists_in_prod,
    is_recidivistic,
    reporter,
    reporter_role,
    created_date,
    changed_date,
):
    conn, cursor = __connect_to_db()
    try:
        cursor.execute(
            """
            INSERT INTO
                workitem_details (id, title, type, severity, priority, feature, target_release, status, exists_in_sit, exists_in_prod, is_recidivistic, reporter, reporter_role, created_date, changed_date)
            VALUES
                (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);
        """,
            (
                id,
                title,
                type,
                severity,
                priority,
                feature,
                target_release,
                status,
                exists_in_sit,
                exists_in_prod,
                is_recidivistic,
                reporter,
                reporter_role,
                created_date,
                changed_date,
            ),
        )
    finally:
        __close_db(conn)
