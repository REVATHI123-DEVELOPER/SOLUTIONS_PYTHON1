def get_repo_id_for_pr(id):
    conn, cursor = __connect_to_db()
    try:
        cursor.execute(
            """
                SELECT
                    repo_id
                FROM
                    pr_workitem_details
                WHERE
                    pr_id = ?;
            """,
            (id,),
        )
        rows = cursor.fetchall()
        # Here all the rows will have same repo_id. So we select first row
        row = rows[0]
        return row[0]
    finally:
        __close_db(conn)


